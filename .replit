modules = ["nodejs-20", "web", "bash", "python-base-3.13"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[objectStorage]
defaultBucketID = "replit-objstore-8623ddf9-21bb-4bbf-a2c5-4c2d0d90bff0"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
